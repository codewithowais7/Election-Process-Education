{
  "name": "votewise-election-education",
  "version": "1.0.0",
  "description": "AI-powered Election Process Education Assistant — Hack2Skill 2026",
  "main": "index.html",
  "scripts": {
    "start": "http-server -p 8080 --cors -c-1",
    "dev": "http-server -p 3000 --cors -c-1 -o",
    "test": "jest --verbose",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "election",
    "education",
    "india",
    "voting",
    "civic",
    "gemini",
    "google-maps",
    "hack2skill",
    "hackathon"
  ],
  "author": "VoteWise Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "dependencies": {
    "http-server": "^14.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "components/**/*.js",
      "services/**/*.js",
      "app.js"
    ],
    "coverageReporters": ["text", "html"],
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    }
  },
  "babel": {
    "presets": [
      ["@babel/preset-env", { "targets": { "node": "current" } }]
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
